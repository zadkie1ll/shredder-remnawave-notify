REMNA_WEBHOOK_SECRET=change-me-to-the-same-value-as-WEBHOOK_SECRET_HEADER
REMNA_WEBHOOK_HOST=0.0.0.0
REMNA_WEBHOOK_PORT=8097
REMNA_LOG_LEVEL=info

REMNA_REDIS_HOST=127.0.0.1
REMNA_REDIS_PORT=6379
REMNA_REDIS_PASSWORD=
REMNA_REDIS_DB=0

REMNA_VPN_BOT_QUEUE=monkey-island-vpn-bot
REMNA_VPS_BOT_QUEUE=monkey-island-vps-bot
REMNA_MESSAGE_SERVICE=monkey-island-vpn-bot
REMNA_REDIS_KEY_PREFIX=remnawave-webhook-notify
REMNA_DEDUPE_TTL_SECONDS=3888000

# 48h and expired+24h events are ignored by default because the old bot contract
# only used 3-days-left, 1-day-left and subscription-expired.
REMNA_NOTIFY_48H_TYPE=
REMNA_NOTIFY_EXPIRED_24H_TYPE=

# 0 disables replay-window checks. Keep enabled in production.
REMNA_SIGNATURE_TOLERANCE_SECONDS=600
