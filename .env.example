REMNA_WEBHOOK_SECRET=change-me-to-the-same-value-as-WEBHOOK_SECRET_HEADER
REMNA_WEBHOOK_HOST=0.0.0.0
REMNA_WEBHOOK_PORT=8097
REMNA_LOG_LEVEL=info

REMNA_REDIS_HOST=127.0.0.1
REMNA_REDIS_PORT=6379
REMNA_REDIS_PASSWORD=
REMNA_REDIS_DB=0

REMNA_VPN_BOT_QUEUE=shredder-vpn-bot
REMNA_REDIS_KEY_PREFIX=remnawave-webhook-notify
REMNA_DEDUPE_TTL_SECONDS=3888000

# Optional event notification types. Keep 48h empty until vpn-bot supports it.
REMNA_NOTIFY_48H_TYPE=
REMNA_NOTIFY_EXPIRED_24H_TYPE=subscription-expired

# Enables traffic polling for conversion events and referral traffic bonuses.
REMNA_TRAFFIC_WATCHER_ENABLED=false
REMNA_TRAFFIC_WATCHER_INTERVAL_SECONDS=900
REMNA_RWMS_ADDR=
REMNA_RWMS_PORT=
REMNA_POSTGRES_HOST=
REMNA_POSTGRES_PORT=5432
REMNA_POSTGRES_USER=
REMNA_POSTGRES_PASSWORD=
REMNA_POSTGRES_DB=

# 0 disables replay-window checks. Keep enabled in production.
REMNA_SIGNATURE_TOLERANCE_SECONDS=600
